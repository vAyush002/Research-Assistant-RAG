# Copy to .env and fill in values:  cp .env.example .env
#
# NOTE: The Streamlit app (streamlit_app.py) takes API keys in the sidebar,
# so it does NOT need this file. These variables are only used by the
# optional FastAPI backend (main.py).

# LLM provider key for the FastAPI backend (Groq by default).
GROQ_API_KEY=your_groq_api_key_here

# Optional model / pipeline overrides
LLM_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_DB_PATH=database/chroma_db
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_DOCUMENTS=3
TEMPERATURE=0.7

# FastAPI backend host/port
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Used only by the legacy two-tier setup (Streamlit calling FastAPI)
API_BASE_URL=http://localhost:8000
